{
  "entities": {
    "App": {
      "title": "App",
      "description": "An application or game in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "string" },
        "iconUrl": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "string" },
        "downloads": { "type": "string" },
        "size": { "type": "string" },
        "description": { "type": "string" },
        "screenshots": { "type": "array" },
        "developer": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "apkUrl": { "type": "string" },
        "iosUrl": { "type": "string" },
        "externalLink": { "type": "string" }
      },
      "required": ["id", "name", "category"]
    },
    "User": {
      "title": "User",
      "description": "A user of the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["id", "name", "email"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "User specific data like balance and library",
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "downloadedApps": { "type": "array" },
        "purchaseLibrary": { "type": "array" }
      }
    },
    "GlobalSettings": {
      "title": "GlobalSettings",
      "description": "Application wide settings like passwords",
      "type": "object",
      "properties": {
        "adminCode": { "type": "string" },
        "moneyCode": { "type": "string" }
      }
    }
  },
  "firestore": {
    "apps/{appId}": {
      "schema": "App",
      "description": "Global apps collection"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Global users collection"
    },
    "users/{userId}/settings/default": {
      "schema": "UserSettings",
      "description": "User specific settings"
    },
    "settings/global": {
      "schema": "GlobalSettings",
      "description": "Global application settings"
    }
  }
}
